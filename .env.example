# =====================================================
# ARIF 環境変数設定サンプル
# このファイルをコピーして .env を作成し、実際の値を入力すること
# 仕様書 S-001: APIキー・資格情報は環境変数で管理・コード直書き禁止
# =====================================================

# Anthropic API（討論エンジン・claude-opus-4-20250514）
ANTHROPIC_API_KEY=your_anthropic_api_key

# OpenAI API（ベクトル埋め込み・text-embedding-3-small）
# 仕様書 §7: Anthropic は embedding API を提供しておらず別途必要
OPENAI_API_KEY=your_openai_api_key

# Supabase — REST/Auth（pr-scribe DB 共用・arif PostgreSQL スキーマ）
SUPABASE_URL=https://ozbruhuisxkepivcvynx.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Supabase — asyncpg 直接接続（pgvector クエリ・search_path=arif で自動設定）
# 取得先: Supabase ダッシュボード → Settings → Database → Connection string → URI (Session pooler)
SUPABASE_DB_URL=postgresql://postgres.ozbruhuisxkepivcvynx:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres
