# =====================================================
# PRISM 環境変数設定サンプル
# このファイルをコピーして .env を作成し、実際の値を入力すること
# 仕様書 S-001: APIキー・資格情報は環境変数で管理・コード直書き禁止
# =====================================================

# Anthropic API（討論エンジン・claude-opus-4-6）
ANTHROPIC_API_KEY=your_anthropic_api_key

# Voyage AI（ベクトル埋め込み・voyage-3・仕様書 §7）
VOYAGE_API_KEY=your_voyage_api_key

# Supabase — REST/Auth
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key

# Supabase — JWT検証（Settings → API → JWT Secret）
SUPABASE_JWT_SECRET=your_supabase_jwt_secret

# Supabase — asyncpg 直接接続（pgvector クエリ・search_path=arif で自動設定）
# 取得先: Supabase ダッシュボード → Settings → Database → Connection string → URI (Session pooler)
SUPABASE_DB_URL=postgresql://postgres.your-project:[YOUR-PASSWORD]@aws-0-ap-northeast-1.pooler.supabase.com:5432/postgres

# メール通知（任意・N-002 仕様）
# 未設定の場合、メール通知は無効になる（熟議自体は正常動作する）
ARIF_SMTP_HOST=smtp.example.com
ARIF_SMTP_PORT=587
ARIF_SMTP_USER=your_smtp_user
ARIF_SMTP_PASS=your_smtp_password
ARIF_SMTP_FROM=prism@example.com
